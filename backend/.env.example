# Database
DATABASE_URL=postgresql://hruser:hrpass@localhost:5432/hrplatform

# JWT — CHANGE THIS in production: openssl rand -hex 32
SECRET_KEY=dev-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# Qdrant
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=hr_documents

# Embedding (downloads automatically on first run)
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DIM=1024

# LLM — Ollama local
LLM_BASE_URL=http://localhost:11434
LLM_MODEL=llama3.1:8b

# Redis
REDIS_URL=redis://localhost:6379/0

# File storage
UPLOAD_DIR=./uploads
DEBUG=false
